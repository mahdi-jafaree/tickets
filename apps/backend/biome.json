{
	"root": false,
	"$schema": "https://biomejs.dev/schemas/2.3.0/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"includes": ["src/**/*.ts", "src/**/*.tsx", "!node_modules", "!.next", "!dist", "!build"],
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
    "formatWithErrors":true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}, "css":{
    "parser": {
      "tailwindDirectives": true
    }
  },
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
